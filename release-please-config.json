{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "tools/audio-lab/backend/Cargo.toml"
        },
        {
          "type": "json",
          "path": "tools/audio-lab/frontend/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
