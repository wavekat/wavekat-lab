# Copy to `.env` (already gitignored) and fill in real values.
# Loaded automatically by notebooks via python-dotenv when present.

# OpenRouter — used by notebooks/smart-turn-mining/05_score_llm.ipynb.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# WaveKat platform — used by notebooks/smart-turn-mining/06_upload_to_platform.ipynb.
# Mint the token in the platform UI under Profile → CLI tokens.
WAVEKAT_API_URL=https://localhost:5020
WAVEKAT_API_TOKEN=wkcli_...
WAVEKAT_PROJECT_ID=
